# Example environment for dual OmbRouter processes (comments only — copy values to your shell or unit files).
# Do not commit real API keys.

# --- Instance A: x402 (or moonpay) — images, /v1/audio/*, partner APIs ---
# BLOCKRUN_PROXY_PORT=8402
# OMBROUTER_UPSTREAM_MODE=x402
# BLOCKRUN_WALLET_KEY=0x...   # optional if wallet file exists

# --- Instance B: apiKey — chat completions with your own upstream ---
# BLOCKRUN_PROXY_PORT=8403
# OMBROUTER_UPSTREAM_MODE=apiKey
# OMBROUTER_UPSTREAM_API_BASE=https://api.openai.com/v1
# OMBROUTER_UPSTREAM_API_KEY=sk-...
# Optional: forward images/audio/partner to upstreamApiBase with Bearer (no second x402 proxy):
# OMBROUTER_APIKEY_AUX_ROUTES=true

# --- OpenClaw gateway (same machine as apiKey chat) ---
# The gateway process needs the SAME port as the apiKey OmbRouter instance so
# injectModelsConfig writes models.providers.blockrun.baseUrl correctly:
# export BLOCKRUN_PROXY_PORT=8403
